# Required for agents + embeddings
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-nano
# Optional override for Digital Twin chat (`/twin`).
TWIN_MODEL=

# Leonardo image generation (workflow node `media.gemini_image` / FLUX Dev)
LEONARDO_API_KEY=

# Google Search via Serper (Trend Hunter)
SERPER_API_KEY=

# Optional: ChromaDB persistence (default ./memory/performance_db)
CHROMA_PERSIST_DIR=

# Voice training from Instagram reels (profile sample kind + Apify + OpenAI transcriptions)
# APIFY_API_TOKEN and OPENAI_API_KEY required when using "Instagram profile" rows in /voice.
VOICE_IG_MAX_REELS=6
# Optional: defaults to gpt-4o-transcribe (see OpenAI Audio transcription / speech-to-text docs)
# OPENAI_TRANSCRIBE_MODEL=

# Optional: Instagram scraping via Apify (hashtag + creator profile actors; workflow + --instagram)
APIFY_API_TOKEN=
# Override default actors if needed:
# APIFY_INSTAGRAM_ACTOR=apify/instagram-hashtag-scraper
# APIFY_INSTAGRAM_PROFILE_ACTOR=instagram-scraper/instagram-profile-posts-scraper

# Optional: MongoDB — voice chunks for Twin `query_creator_knowledge` (captions, transcripts, hooks).
# Set URI and restart API; then re-save or PATCH a voice profile to upsert documents.
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/
# MONGODB_DATABASE=launchy
# MONGODB_VOICE_COLLECTION=voice_context
# MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000

# Frontend (Vite) — logo tiles on marketing pages, API origin overrides; see web/.env.example
# NEXT_PUBLIC_LOGO_DEV_KEY=
