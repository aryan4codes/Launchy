      },
      "position": {
        "x": 220.0,
        "y": 120.0
      }
    },
    {
      "id": "psych",
      "type": "agent.crewai",
      "params": {
        "role": "Audience Psychologist",
        "goal": "Map emotional triggers and objections grounded in signals.",
        "backstory": "Infer only from the supplied signal block.",
        "task_description_template": "{{ upstream['merge_signals']['text'] }}",
        "expected_output": "Short bullet memo: triggers | objections | language hooks per sub-theme."
      },
      "position": {
        "x": 420.0,
        "y": 0.0
      }
    },
    {
      "id": "angles",
      "type": "agent.crewai",
      "params": {
        "role": "Content Strategist",
        "goal": "Turn psychology into differentiated angles.",
        "backstory": "Align angles with niche relevance only.",
        "task_description_template": "Psych memo:\n{{ upstream['psych']['text'] }}",
        "expected_output": "Numbered angles with suggested platform emphasis."
      },
      "position": {
        "x": 640.0,
        "y": 0.0
      }
    },
    {
      "id": "copy",
      "type": "agent.crewai",
      "params": {
        "role": "Copywriter",
        "goal": "Draft native social copy snippets per angle.",
        "backstory": "Keep hooks truthful to inputs.",
        "task_description_template": "Angles brief:\n{{ upstream['angles']['text'] }}",
        "expected_output": "Grouped draft lines per angle (~2 variations each)."
      },
      "position": {
        "x": 860.0,
        "y": 0.0
      }
    },
    {
      "id": "creative_brief",
      "type": "agent.crewai",
      "params": {
        "role": "Creative Director",
        "goal": "Add concise visual/format notes to each draft snippet.",
        "backstory": "Suggest carousel/reel/static cues without hallucinating logos.",
        "task_description_template": "Draft copy pack:\n{{ upstream['copy']['text'] }}",
        "expected_output": "Annotated creative brief snippets."
      },
      "position": {
        "x": 1080.0,
        "y": 0.0
      }
    },
    {
      "id": "score",
      "type": "agent.crewai",
      "params": {
        "role": "Performance Analyst",
        "goal": "Rough score each snippet 0–100 plus one-line rationale (no tooling).",
        "backstory": "Calibrated heuristics for hook sharpness only.",
        "task_description_template": "Creative snippets with briefs:\n{{ upstream['creative_brief']['text'] }}",
        "expected_output": "Table-like rankings with score and rationale per snippet."
      },
      "position": {
        "x": 1300.0,
        "y": 0.0
      }
