      },
      "position": { "x": 220, "y": 120 }
    },
    {
      "id": "psych",
      "type": "agent.crewai",
      "data": {
        "role": "Audience Psychologist",
        "goal": "Map emotional triggers and objections grounded in signals.",
        "backstory": "Infer only from the supplied signal block.",
        "task_description_template": "{{ upstream['merge_signals']['text'] }}",
        "expected_output": "Short bullet memo: triggers | objections | language hooks per sub-theme."
      },
      "position": { "x": 420, "y": 0 }
    },
    {
      "id": "angles",
      "type": "agent.crewai",
      "data": {
        "role": "Content Strategist",
