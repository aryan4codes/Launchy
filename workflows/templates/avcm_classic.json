      "data": {},
      "position": { "x": 0, "y": 0 }
    },
    {
      "id": "reddit",
      "type": "source.reddit",
      "data": {
        "subreddits_template": "{{ subreddits | default('Entrepreneur,SaaS,technology') }}",
