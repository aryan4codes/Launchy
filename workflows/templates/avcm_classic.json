      },
      "position": { "x": 640, "y": 0 }
    },
    {
      "id": "copy",
      "type": "agent.crewai",
      "data": {
        "role": "Copywriter",
        "goal": "Draft native social copy snippets per angle.",
        "backstory": "Keep hooks truthful to inputs.",
        "task_description_template": "Angles brief:\n{{ upstream['angles']['text'] }}",
        "expected_output": "Grouped draft lines per angle (~2 variations each)."
      },
      "position": { "x": 860, "y": 0 }
    },
    {
      "id": "creative_brief",
      "type": "agent.crewai",
      "data": {
        "role": "Creative Director",
        "goal": "Add concise visual/format notes to each draft snippet.",
        "backstory": "Suggest carousel/reel/static cues without hallucinating logos.",
        "task_description_template": "Draft copy pack:\n{{ upstream['copy']['text'] }}",
        "expected_output": "Annotated creative brief snippets."
      },
      "position": { "x": 1080, "y": 0 }
    },
    {
      "id": "score",
      "type": "agent.crewai",
      "data": {
        "role": "Performance Analyst",
        "goal": "Rough score each snippet 0–100 plus one-line rationale (no tooling).",
